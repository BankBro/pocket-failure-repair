{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pfr.local/schemas/third_party_audit/run/run_metadata_v0_1.json",
  "title": "Third-party audit run metadata v0.1",
  "description": "Draft schema for third-party method run metadata. This schema is draft-ready and not analysis-frozen.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "schema_path",
    "run_id",
    "method",
    "run_boundary_label",
    "algorithm_changed",
    "dataset_name",
    "dataset_version",
    "dataset_view_id",
    "split_id",
    "leakage_check_status",
    "resource_budget_config_version",
    "label_protocol_version"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "run_metadata_v0_1"},
    "schema_path": {"type": "string", "const": "schemas/third_party_audit/run/run_metadata_v0_1.json"},
    "run_id": {"type": "string"},
    "method": {"type": "string"},
    "run_boundary_label": {
      "type": "string",
      "enum": [
        "original_protocol_reproduction",
        "instrumented_reproduction",
        "audit_protocol_run",
        "adapted_baseline",
        "stage_limited_audit",
        "selected_output_residual_audit",
        "excluded"
      ]
    },
    "upstream_repo": {"type": ["string", "null"]},
    "upstream_commit": {"type": ["string", "null"]},
    "fork_repo": {"type": ["string", "null"]},
    "fork_branch": {"type": ["string", "null"]},
    "fork_commit": {"type": ["string", "null"]},
    "patches": {"type": "array", "items": {"type": "string"}},
    "algorithm_changed": {"type": "boolean"},
    "checkpoint_id": {"type": ["string", "null"]},
    "checkpoint_source": {"type": ["string", "null"]},
    "checkpoint_sha256": {"type": ["string", "null"]},
    "training_data_status": {"type": "string", "enum": ["known", "partial", "training_data_unknown", "not_applicable", "unknown"]},
    "dataset_name": {"type": "string"},
    "dataset_version": {"type": "string"},
    "raw_dataset_id": {"type": ["string", "null"]},
    "dataset_view_id": {"type": "string"},
    "split_id": {"type": "string"},
    "preprocessing_id": {"type": ["string", "null"]},
    "raw_checksum": {"type": ["string", "null"]},
    "view_checksum": {"type": ["string", "null"]},
    "split_checksum": {"type": ["string", "null"]},
    "leakage_check_status": {"type": "string", "enum": ["passed", "possible_overlap", "unknown_risk", "failed", "not_checked"]},
    "leakage_report_path": {"type": ["string", "null"]},
    "seed": {"type": ["integer", "null"]},
    "sampling_budget": {"type": ["integer", "number", "null"]},
    "config_hash": {"type": ["string", "null"]},
    "command": {"type": ["string", "null"]},
    "environment": {"type": ["string", "null"]},
    "hardware": {"type": ["string", "null"]},
    "stdout_path": {"type": ["string", "null"]},
    "stderr_path": {"type": ["string", "null"]},
    "output_manifest_path": {"type": ["string", "null"]},
    "resource_budget_config_version": {"type": "string"},
    "resource_budget_config_hash": {"type": ["string", "null"]},
    "label_protocol_version": {"type": "string"},
    "label_config_hash": {"type": ["string", "null"]},
    "tool_versions_lock_path": {"type": ["string", "null"]}
  }
}
