{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pfr.local/schemas/data/datasets/manifests/lineage/dataset_lineage_raw_to_entry_v0_1.json",
  "title": "Dataset raw-to-entry lineage index v0.1",
  "description": "Schema for data/datasets/<dataset_id>/manifests/lineage/raw_to_entry_index_v1.json.",
  "type": "object",
  "additionalProperties": true,
  "required": ["dataset_id", "lookup_key", "raw_to_entry"],
  "properties": {
    "schema_version": {"type": "string", "const": "dataset_lineage_raw_to_entry_v0_1"},
    "schema_path": {"type": "string", "const": "schemas/data/datasets/manifests/lineage/dataset_lineage_raw_to_entry_v0_1.json"},
    "created_or_updated": {"type": ["string", "null"]},
    "dataset_id": {"type": "string"},
    "dataset_version": {"type": "string"},
    "lookup_key": {"type": "string"},
    "purpose": {"type": ["string", "null"]},
    "entry_count": {"type": ["integer", "null"], "minimum": 0},
    "link_count": {"type": ["integer", "null"], "minimum": 0},
    "entry_index_path": {"type": ["string", "null"]},
    "entry_manifest_path": {"type": ["string", "null"]},
    "raw_manifest_path": {"type": ["string", "null"]},
    "dataset_view_manifest_path": {"type": ["string", "null"]},
    "split_manifest_path": {"type": ["string", "null"]},
    "raw_to_entry": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["raw_path", "links"],
        "properties": {
          "raw_path": {"type": "string"},
          "links": {
            "type": "array",
            "items": {"$ref": "#/$defs/lineage_link"}
          }
        }
      }
    }
  },
  "$defs": {
    "lineage_link": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sample_id", "entry_path", "raw_path", "raw_role"],
      "properties": {
        "sample_id": {"type": "string"},
        "complex_id": {"type": ["string", "null"]},
        "dataset_id": {"type": "string"},
        "dataset_version": {"type": ["string", "null"]},
        "entry_path": {"type": "string"},
        "entry_index_path": {"type": ["string", "null"]},
        "entry_line_number": {"type": ["integer", "null"], "minimum": 1},
        "entry_index_sha256": {"type": ["string", "null"]},
        "entry_manifest_path": {"type": ["string", "null"]},
        "raw_path": {"type": "string"},
        "raw_role": {"type": "string"},
        "raw_sha256": {"type": ["string", "null"]},
        "raw_manifest_path": {"type": ["string", "null"]},
        "dataset_view_manifest_path": {"type": ["string", "null"]},
        "split_manifest_path": {"type": ["string", "null"]}
      }
    }
  }
}
