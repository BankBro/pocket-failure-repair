{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pfr.local/schemas/data/catalog/dataset_raw_reconciliation_v0_1.json",
  "title": "Dataset raw reconciliation v0.1",
  "description": "Schema for cross-dataset raw-file reconciliation records under data/catalog/.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "schema_path", "raw_manifests", "overlap"],
  "properties": {
    "schema_version": {"type": "string", "const": "dataset_raw_reconciliation_v0_1"},
    "schema_path": {"type": "string", "const": "schemas/data/catalog/dataset_raw_reconciliation_v0_1.json"},
    "created_or_updated": {"type": ["string", "null"]},
    "notes": {"type": "array", "items": {"type": "string"}},
    "raw_manifests": {"type": "array", "items": {"type": "string"}},
    "overlap_complex_count": {"type": ["integer", "null"], "minimum": 0},
    "overlap": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["complex_id", "action"],
        "properties": {
          "complex_id": {"type": "string"},
          "action": {"type": "string"},
          "protein_raw_sha256_match": {"type": ["boolean", "null"]},
          "protein_clean_sha256_match": {"type": ["boolean", "null"]},
          "ligand_pdb_sha256_match": {"type": ["boolean", "null"]},
          "ligand_sdf_sha256_match": {"type": ["boolean", "null"]},
          "smoke_ligand_path": {"type": ["string", "null"]},
          "smoke_ligand_sha256": {"type": ["string", "null"]},
          "smoke_plus_ligand_path": {"type": ["string", "null"]},
          "smoke_plus_ligand_sha256": {"type": ["string", "null"]}
        }
      }
    }
  }
}
